<div class="space-y-6">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @contact.full_name %> <%= "★" if @contact.starred? %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= @contact.meta(:job_title).presence || "No job title" %> <%= "at #{@contact.meta(:company)}" if @contact.meta(:company).present? %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_contact_path(@contact), class: "inline-flex rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <%= link_to "Delete", contact_path(@contact), data: { turbo_method: :delete, turbo_confirm: "Delete contact?" }, class: "inline-flex rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700" %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <section class="rounded-lg border border-gray-200 bg-white p-4">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-500">Profile</h2>
      <% if @contact.photo_url.present? %>
        <img src="<%= @contact.photo_url %>" alt="Contact photo" class="h-24 w-24 rounded-full object-cover" />
      <% else %>
        <div class="flex h-24 w-24 items-center justify-center rounded-full bg-gray-100 text-2xl text-gray-600">
          <%= contact_initials(@contact).presence || "?" %>
        </div>
      <% end %>
    </section>

    <section class="rounded-lg border border-gray-200 bg-white p-4">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-500">Contact info</h2>
      <dl class="space-y-2 text-sm">
        <div><dt class="font-medium text-gray-700">Emails</dt><dd class="text-gray-900"><%= @contact.emails.map(&:value).presence&.join(", ") || "-" %></dd></div>
        <div><dt class="font-medium text-gray-700">Phones</dt><dd class="text-gray-900"><%= @contact.phones.map { |p| p.e164.presence || p.value }.presence&.join(", ") || "-" %></dd></div>
        <div><dt class="font-medium text-gray-700">Website</dt><dd class="text-gray-900"><%= @contact.meta(:website).presence || "-" %></dd></div>
        <div><dt class="font-medium text-gray-700">Websites</dt><dd class="text-gray-900"><%= @contact.websites.map(&:url).presence&.join(", ") || "-" %></dd></div>
        <div><dt class="font-medium text-gray-700">Birthday</dt><dd class="text-gray-900"><%= @contact.meta(:birthday).presence || @contact.events.find { |e| e.event_type == "birthday" }&.event_date || "-" %></dd></div>
      </dl>
    </section>

    <section class="rounded-lg border border-gray-200 bg-white p-4">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-500">Address & travel</h2>
      <dl class="space-y-2 text-sm">
        <div><dt class="font-medium text-gray-700">Current city</dt><dd class="text-gray-900"><%= @contact.current_city.presence || "-" %></dd></div>
        <div><dt class="font-medium text-gray-700">Departure city</dt><dd class="text-gray-900"><%= @contact.departure_city.presence || "-" %></dd></div>
        <div><dt class="font-medium text-gray-700">Interested region</dt><dd class="text-gray-900"><%= @contact.region_name.presence || "-" %></dd></div>
        <div><dt class="font-medium text-gray-700">Addresses</dt><dd class="text-gray-900"><%= @contact.addresses.map { |a| [a.city, a.departure_city].compact.join(" -> ") }.presence&.join(", ") || "-" %></dd></div>
        <div><dt class="font-medium text-gray-700">Sync eligible</dt><dd class="text-gray-900"><%= @contact.sync_eligible? ? "Yes" : "No" %></dd></div>
      </dl>
    </section>
  </div>

  <section class="rounded-lg border border-gray-200 bg-white p-4">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-500">Notes</h2>
    <p class="whitespace-pre-line text-sm text-gray-900"><%= @contact.biography.presence || "-" %></p>
    <p class="mt-3 whitespace-pre-line text-sm text-gray-700"><%= @contact.meta(:notes).presence || "" %></p>
  </section>

  <%= link_to "Back to Contacts", contacts_path, class: "inline-flex rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
</div>
