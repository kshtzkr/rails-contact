<%= render "rails/contact/stylesheet" %>
<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Contacts</h1>
    <%= link_to "Add Contact", new_contact_path, class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
    <%= form_with url: contacts_path, method: :get, local: true, class: "grid grid-cols-1 gap-3 md:grid-cols-4 md:items-end" do |f| %>
      <div>
        <%= f.label :q, "Search", class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.text_field :q, value: @query, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :city, "Current City", class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.text_field :city, value: params[:city], class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :region, "Interested Region", class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.text_field :region, value: params[:region], class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm" %>
      </div>
      <div class="flex gap-2">
        <%= f.submit "Filter", class: "inline-flex rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700" %>
        <%= link_to "Reset", contacts_path, class: "inline-flex rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      </div>
    <% end %>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
    <%= form_with url: bulk_destroy_contacts_path, method: :post, local: true, class: "inline-flex items-center gap-2" do |f| %>
      <%= hidden_field_tag :ids, "", id: "bulk-ids-field" %>
      <%= f.submit "Delete selected", class: "rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white hover:bg-red-700", data: { confirm: "Delete selected contacts?" } %>
    <% end %>
    <%= form_with url: merge_contacts_path, method: :post, local: true, class: "mt-3 flex flex-wrap items-center gap-2 text-sm" do %>
      <label>Merge source</label>
      <%= number_field_tag :source_id, nil, class: "w-28 rounded-md border border-gray-300 px-2 py-1" %>
      <label>into target</label>
      <%= number_field_tag :target_id, nil, class: "w-28 rounded-md border border-gray-300 px-2 py-1" %>
      <%= submit_tag "Merge", class: "rounded-md border border-gray-300 px-3 py-1 hover:bg-gray-50" %>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600">Select</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600">Name</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600">Starred</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600">Company</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600">Email</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600">Phone</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600">Current City</th>
          <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-600">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 bg-white">
        <% @contacts.each do |contact| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3"><input type="checkbox" class="bulk-id-checkbox" value="<%= contact.id %>" /></td>
            <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= contact.full_name %></td>
            <td class="px-4 py-3 text-sm text-gray-700"><%= contact.starred? ? "★" : "-" %></td>
            <td class="px-4 py-3 text-sm text-gray-700"><%= contact.meta(:company).presence || "-" %></td>
            <td class="px-4 py-3 text-sm text-gray-700"><%= contact.primary_email&.value.presence || "-" %></td>
            <td class="px-4 py-3 text-sm text-gray-700"><%= contact.primary_phone&.e164.presence || contact.primary_phone&.value.presence || "-" %></td>
            <td class="px-4 py-3 text-sm text-gray-700"><%= contact.current_city.presence || "-" %></td>
            <td class="px-4 py-3 text-right text-sm">
              <%= link_to "Open", contact_path(contact), class: "font-medium text-blue-600 hover:text-blue-700" %>
            </td>
          </tr>
        <% end %>
        <% if @contacts.empty? %>
          <tr>
            <td colspan="8" class="px-4 py-8 text-center text-sm text-gray-500">No contacts found yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= render "rails/contact/bulk_selection_script" %>
